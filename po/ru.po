#: resources/ui/setup.ui:89
msgid "Select Library"
msgstr "Выбор медиатеки"

#: resources/ui/setup.ui:90
msgid "Choose which library Gelly will use to load your music."
msgstr ""
"Выберите медиатеку, которую Gelly будет использовать для загрузки вашей "
"музыки."

#: resources/ui/setup.ui:105
msgid "Library"
msgstr "Медиатека"

#: resources/ui/setup.ui:112
msgid "Launch Gelly"
msgstr "Запустить Gelly"

#: resources/ui/setup.ui:123 resources/ui/setup.ui:186
msgid "Cancel"
msgstr "Отменить"

#: resources/ui/setup.ui:141
msgid "Quick Connect"
msgstr "Быстрый вход"

#: resources/ui/setup.ui:151
msgid "Enter the code on the Jellyfin web page to complete authentication."
msgstr "Введите код на веб-странице Jellyfin, чтобы завершить аутентификацию."

