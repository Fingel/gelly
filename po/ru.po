msgid "Username"
msgstr "Имя пользователя"

#: resources/ui/setup.ui:47
msgid "Password"
msgstr "Пароль"

#: resources/ui/setup.ui:54
msgid "Connect"
msgstr "Подключение"

#: resources/ui/setup.ui:65 resources/ui/setup.ui:150
