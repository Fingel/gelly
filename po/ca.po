#: resources/ui/setup.ui:105
msgid "Library"
msgstr "Biblioteca"

#: resources/ui/setup.ui:112
msgid "Launch Gelly"
msgstr "Inicia el Gelly"

#: resources/ui/setup.ui:123 resources/ui/setup.ui:186
