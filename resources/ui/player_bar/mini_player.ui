<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <template class="GellyMiniPlayerBar" parent="AdwBreakpointBin">
    <property name="width-request">200</property>
    <property name="height-request">48</property>
    <child>
      <object class="AdwBreakpoint">
        <condition>max-width: 600sp</condition>
        <!-- Hide normal-mode elements -->
        <setter object="artist_button" property="visible">false</setter>
        <setter object="album_button" property="visible">false</setter>
        <setter object="artist_album_separator_label" property="visible">false</setter>
        <setter object="volume_control" property="visible">false</setter>
        <setter object="playback_mode_menu" property="visible">false</setter>
        <setter object="scale_position_label" property="visible">false</setter>
        <setter object="scale_duration_label" property="visible">false</setter>
        <setter object="position_scale" property="visible">false</setter>
        <setter object="info_button" property="visible">false</setter>
        <!-- Show small-mode elements -->
        <setter object="position_label" property="visible">true</setter>
        <setter object="duration_label" property="visible">true</setter>
        <setter object="duration_separator_label" property="visible">true</setter>
        <!-- Misc layout stuff -->
        <setter object="album_art" property="size">42</setter>
        <setter object="title_label" property="halign">start</setter>
        <setter object="song_info_box" property="halign">start</setter>
        <setter object="subtitle_box" property="halign">start</setter>
        <setter object="all_buttons_box" property="orientation">horizontal</setter>
        <setter object="root_box" property="margin-top">3</setter>
        <setter object="root_box" property="margin-bottom">3</setter>
        <setter object="root_box" property="margin-start">3</setter>
        <setter object="root_box" property="margin-end">3</setter>
      </object>
    </child>
    <property name="child">
      <object class="GtkBox" id="root_box">
        <property name="orientation">horizontal</property>
        <property name="visible">true</property>
        <property name="spacing">6</property>
        <property name="margin-start">6</property>
        <property name="margin-end">6</property>
        <property name="margin-top">6</property>
        <property name="margin-bottom">6</property>
        <child>
          <!-- Song info section -->
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="spacing">12</property>
            <property name="hexpand">true</property>
            <child>
              <object class="GellyAlbumArt" id="album_art">
                <property name="size">84</property>
              </object>
            </child>
            <child>
              <object class="GtkBox" id="song_info_box">
                <property name="orientation">vertical</property>
                <property name="spacing">6</property>
                <property name="hexpand">true</property>
                <property name="valign">center</property>
                <!-- song info -->
                  <child>
                    <object class="GtkBox">
                      <property name="orientation">vertical</property>
                      <property name="halign">center</property>
                      <property name="valign">center</property>
                      <property name="hexpand">true</property>
                      <child>
                        <object class="GtkLabel" id="title_label">
                          <property name="ellipsize">end</property>
                          <property name="max-width-chars">30</property>
                          <property name="halign">center</property>
                          <style>
                            <class name="heading"/>
                          </style>
                        </object>
                      </child>
                      <child>
                        <object class="GtkBox" id="subtitle_box">
                          <property name="halign">center</property>
                          <child>
                            <object class="GtkLabel" id="position_label">
                              <property name="ellipsize">end</property>
                              <property name="max_width_chars">90</property>
                              <property name="halign">end</property>
                              <property name="xalign">1.0</property>
                              <property name="visible">false</property>
                              <style>
                                <class name="dimmed"/>
                              </style>
                            </object>
                          </child>
                          <child>
                            <object class="GtkLabel" id="duration_separator_label">
                              <property name="label">/</property>
                              <property name="visible">false</property>
                              <style>
                                <class name="dimmed"/>
                              </style>
                            </object>
                          </child>
                          <child>
                            <object class="GtkLabel" id="duration_label">
                              <property name="ellipsize">end</property>
                              <property name="max_width_chars">90</property>
                              <property name="halign">start</property>
                              <property name="xalign">0.0</property>
                              <property name="visible">false</property>
                              <style>
                                <class name="dimmed"/>
                              </style>
                            </object>
                          </child>
                          <child>
                            <object class="GtkButton" id="artist_button">
                              <property name="focusable">True</property>
                              <property name="halign">end</property>
                              <property name="has-frame">False</property>
                              <style>
                                <class name="flat"/>
                                <class name="dimmed"/>
                                <class name="song-link"/>
                              </style>
                              <child>
                                <object class="GtkLabel" id="artist_label">
                                  <property name="ellipsize">end</property>
                                  <property name="max_width_chars">90</property>
                                </object>
                              </child>
                            </object>
                          </child>
                          <child>
                            <object class="GtkLabel" id="artist_album_separator_label">
                              <property name="focusable">False</property>
                              <property name="label"> - </property>
                              <property name="halign">center</property>
                              <style>
                                <class name="dimmed"/>
                              </style>
                            </object>
                          </child>
                          <child>
                            <object class="GtkButton" id="album_button">
                              <property name="focusable">True</property>
                              <property name="has-frame">False</property>
                              <property name="halign">start</property>
                              <style>
                                <class name="flat"/>
                                <class name="dimmed"/>
                                <class name="song-link"/>
                              </style>
                              <child>
                                <object class="GtkLabel" id="album_label">
                                  <property name="ellipsize">end</property>
                                  <property name="halign">start</property>
                                  <property name="max_width_chars">90</property>
                                </object>
                              </child>
                            </object>
                          </child>
                        </object>
                      </child>
                  </object>
                </child>
                <!-- seek bar -->
                <child>
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="halign">fill</property>
                    <property name="hexpand">true</property>
                    <property name="valign">center</property>
                    <property name="spacing">3</property>
                    <child>
                      <object class="GtkLabel" id="scale_position_label">
                        <property name="label">0:00</property>
                        <property name="width-chars">4</property>
                        <style>
                          <class name="caption"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkScale" id="position_scale">
                        <property name="hexpand">true</property>
                        <property name="draw-value">false</property>
                        <property name="width-request">64</property>
                        <property name="adjustment">
                          <object class="GtkAdjustment">
                            <property name="lower">0</property>
                            <property name="upper">100</property>
                            <property name="step-increment">1</property>
                            <property name="page-increment">10</property>
                          </object>
                        </property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLabel" id="scale_duration_label">
                        <property name="label">0:00</property>
                        <property name="width-chars">4</property>
                        <style>
                          <class name="caption"/>
                        </style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkButton" id="info_button">
                        <property name="margin-start">2</property>
                        <child>
                          <object class="GtkImage" id="info_icon">
                            <property name="icon-name">help-about-symbolic</property>
                            <property name="icon-size">1</property>
                          </object>
                        </child>
                        <style>
                          <class name="flat"/>
                        </style>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="all_buttons_box">
            <property name="orientation">vertical</property>
            <property name="spacing">6</property>
            <property name="halign">end</property>
            <property name="valign">center</property>
            <child>
              <object class="GtkBox">
                <property name="orientation">horizontal</property>
                <property name="halign">end</property>
                <property name="valign">center</property>
                <property name="spacing">3</property>
                <child>
                  <object class="GtkButton" id="lyrics_button">
                    <property name="icon-name">subtitles-symbolic</property>
                    <property name="visible">false</property>
                    <property name="tooltip-text">Lyrics</property>
                    <style>
                      <class name="flat" />
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GellyPlaybackModeMenu" id="playback_mode_menu">
                  </object>
                </child>
                <child>
                  <object class="GellyVolumeButton" id="volume_control"/>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="orientation">horizontal</property>
                <property name="halign">end</property>
                <property name="valign">center</property>
                <property name="spacing">3</property>
                <child>
                  <object class="GtkButton" id="prev_button">
                    <property name="icon-name">media-skip-backward-symbolic</property>
                    <property name="tooltip-text">Previous</property>
                    <style>
                      <class name="circular"/>
                      <class name="flat"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="play_pause_button">
                    <property name="icon-name">media-playback-start-symbolic</property>
                    <property name="tooltip-text">Play</property>
                    <style>
                      <class name="circular"/>
                      <class name="flat"/>
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkButton" id="next_button">
                    <property name="icon-name">media-skip-forward-symbolic</property>
                    <property name="tooltip-text">Next</property>
                    <style>
                      <class name="circular"/>
                      <class name="flat"/>
                    </style>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </template>
</interface>
